#!/bin/sh

# script/bootstrap: Resolve all dependencies that the application requires to
#                   run. Uses Mise for Ruby and CMake; Bundler for gems.

set -e

cd "$(dirname "$0")/.."

if [ -f ".tool-versions" ]; then
  if ! command -v mise >/dev/null 2>&1; then
    echo "==> Mise is required. Install it from https://mise.jdx.dev/"
    exit 1
  fi
  echo "==> Installing tools from .tool-versions (Ruby, CMake)…"
  mise install
fi

if [ -f "Gemfile" ]; then
  echo "==> Installing gem dependencies…"
  bundle config set path vendor/bundle
  if [ -f ".tool-versions" ] && command -v mise >/dev/null 2>&1; then
    mise exec -- bundle check >/dev/null 2>&1 || mise exec -- bundle install --jobs 4 --retry 3
  else
    bundle check >/dev/null 2>&1 || bundle install --jobs 4 --retry 3
  fi
fi
