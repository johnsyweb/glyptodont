#!/bin/sh
# Check that commit messages in the given range follow Conventional Commits.
# Usage: script/check-commit-messages [range]
#   range: git revision range (e.g. HEAD~3..HEAD or abc..HEAD); default HEAD.
# If .github/conventional-commits-since exists and contains a ref, only commits
# at or after that ref are checked (older commits are ignored).

set -e

cd "$(dirname "$0")/.."

range="${1:-HEAD}"
since_ref=""
since_sha=""
if [ -f .github/conventional-commits-since ]; then
  since_ref=$(cat .github/conventional-commits-since | sed 's/[[:space:]]//g')
  [ -n "$since_ref" ] && since_sha=$(git rev-parse "$since_ref")
fi

for rev in $(git rev-list "$range"); do
  if [ -n "$since_sha" ]; then
    if [ "$rev" != "$since_sha" ] && ! git merge-base --is-ancestor "$since_ref" "$rev" 2>/dev/null; then
      continue
    fi
  fi
  git log -1 --format=%B "$rev" > /tmp/commit-msg-check.$$
  if ! ./.githooks/commit-msg /tmp/commit-msg-check.$$; then
    echo "Invalid commit: $rev" >&2
    git log -1 --oneline "$rev" >&2
    rm -f /tmp/commit-msg-check.$$
    exit 1
  fi
  rm -f /tmp/commit-msg-check.$$
done
